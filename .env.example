# Store screenshot capture mode (web only). Do not enable in production builds.
EXPO_PUBLIC_STORE_CAPTURE=false

# Display name shown on device home screen and Play Store (override before release).
EXPO_PUBLIC_APP_NAME=Guitar Trainer

# Android applicationId. Must be final before first Play Console upload.
EXPO_PUBLIC_ANDROID_PACKAGE=com.placeholder.guitartrainer

# Set after `eas init` / linking the Expo project (required for EAS Build).
EAS_PROJECT_ID=05b233bc-5256-4353-aad6-dfa30c9cba92
