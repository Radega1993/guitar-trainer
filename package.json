{
  "name": "guitar-trainer",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "expo": "~57.0.4",
    "expo-asset": "^57.0.3",
    "expo-audio": "^57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-splash-screen": "^57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^57.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "playwright": "^1.61.1",
    "sharp": "^0.34.4",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "npx expo lint",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "store:capture": "playwright test scripts/google-play/capture-screenshots.ts",
    "store:generate": "tsx scripts/google-play/generate-marketing-assets.ts",
    "store:validate": "tsx scripts/google-play/validate-assets.ts",
    "store:prepare": "npm run store:capture && npm run store:generate && npm run store:validate",
    "release:check": "npm run doctor && npm run typecheck && npm run test && npm run lint",
    "release:assets": "npm run store:validate",
    "release:prepare": "npm run release:check && npm run release:assets"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "configFile": false,
          "babelrc": false,
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                }
              }
            ],
            "@babel/preset-typescript"
          ]
        }
      ]
    },
    "moduleNameMapper": {
      "\\.mp3$": "<rootDir>/src/services/audio/__mocks__/audioFileMock.ts",
      "\\.png$": "<rootDir>/src/services/audio/__mocks__/audioFileMock.ts"
    }
  },
  "private": true
}
